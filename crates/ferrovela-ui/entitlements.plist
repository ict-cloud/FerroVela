<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Proxy listener on loopback port -->
    <key>com.apple.security.network.server</key>
    <true/>

    <!-- Outbound connections: upstream proxy, PAC fetch, direct tunnels -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- rquickjs/QuickJS JIT compilation for PAC file evaluation -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Allow system Kerberos/GSSAPI libraries and any non-Apple dylibs -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
